# Copy this file to .env.local, then replace placeholders there only.
# Never put real credentials in this example file or commit .env.local.
# Provider values: kimi (default) or deepseek.
AI_PROVIDER=kimi

# Kimi API docs: https://platform.kimi.com/docs/api/overview
MOONSHOT_API_KEY=replace-with-your-moonshot-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# DeepSeek API docs: https://api-docs.deepseek.com
DEEPSEEK_API_KEY=replace-with-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Tavily Search and Extract docs: https://docs.tavily.com/documentation/api-reference
TAVILY_API_KEY=replace-with-your-tavily-key
TAVILY_BASE_URL=https://api.tavily.com
