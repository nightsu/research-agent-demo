# kimi (default) or deepseek
AI_PROVIDER=kimi

# Kimi API: https://platform.kimi.com
MOONSHOT_API_KEY=replace-with-your-moonshot-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# DeepSeek API: https://platform.deepseek.com
DEEPSEEK_API_KEY=replace-with-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Tavily Search and Extract: https://app.tavily.com
TAVILY_API_KEY=replace-with-your-tavily-key
TAVILY_BASE_URL=https://api.tavily.com
